# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (Backend / Service Role) ────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ── AI Models ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=your-gemini-api-key
ASSEMBLYAI_API_KEY=your-assemblyai-key

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY=your-access-key-id
CLOUDFLARE_R2_SECRET_KEY=your-secret-access-key
CLOUDFLARE_R2_BUCKET_VIDEOS=vfxb-videos
CLOUDFLARE_R2_BUCKET_EXPORTS=vfxb-exports
# Public URL for R2 (configure custom domain or use r2.dev URL)
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── Cache / Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@vfxb.ai

# ── Error Monitoring ──────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── App URLs ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8000
